-- ============================================================================
-- PHASE 1: DATABASE SCHEMA CREATION (DDL) & DATA INSERTION (DML)
-- ============================================================================

-- 1. Create Main Tables & Define Relationships
CREATE TABLE customers (
    customer_id SERIAL PRIMARY KEY,
    first_name VARCHAR(100),
    last_name VARCHAR(100),
    email VARCHAR(150),
    country VARCHAR(100),
    signup_date TIMESTAMP
);

CREATE TABLE categories (
    category_id SERIAL PRIMARY KEY,
    category_name VARCHAR(100)
);

CREATE TABLE products (
    product_id SERIAL PRIMARY KEY,
    product_name VARCHAR(150),
    category_id INT REFERENCES categories(category_id),
    price NUMERIC(10, 2),
    stock INT
);

CREATE TABLE orders (
    order_id SERIAL PRIMARY KEY,
    customer_id INT REFERENCES customers(customer_id),
    order_date TIMESTAMP,
    status VARCHAR(50)
);

CREATE TABLE order_details (
    order_detail_id SERIAL PRIMARY KEY,
    order_id INT REFERENCES orders(order_id),
    product_id INT REFERENCES products(product_id),
    quantity INT,
    discount NUMERIC(5, 2)
);

-- 2. Generate Synthetic Big Data (Mocking Real Warehouse Environments)
-- Generate 500 customers with random country distribution and formatting flaws
INSERT INTO customers (first_name, last_name, email, country, signup_date)
SELECT 
    'User_' || i AS first_name,
    CASE WHEN i % 10 = 0 THEN NULL ELSE 'LastName_' || i END AS last_name,
    LOWER('  USER_' || i || '@globalmart.com  ') AS email, 
    CASE 
        WHEN i % 5 = 0 THEN 'Egypt'
        WHEN i % 5 = 1 THEN 'Germany'
        WHEN i % 5 = 2 THEN 'USA'
        WHEN i % 5 = 3 THEN 'UAE'
        ELSE 'KSA'
    END AS country,
    NOW() - (i || ' days')::INTERVAL AS signup_date
FROM generate_series(1, 500) i;

-- Insert core inventory categories
INSERT INTO categories (category_name) VALUES ('Electronics'), ('Clothing'), ('Home & Kitchen'), ('Books');

-- Generate 100 distinct products spread across categories
INSERT INTO products (product_name, category_id, price, stock)
SELECT 
    'Product_' || i AS product_name,
    (i % 4) + 1 AS category_id,
    (10.50 + (i * 2.5))::NUMERIC(10,2) AS price,
    CASE WHEN i % 12 = 0 THEN 0 ELSE 50 + (i * 2) END AS stock 
FROM generate_series(1, 100) i;

-- Generate 2000 historical order entries
INSERT INTO orders (customer_id, order_date, status)
SELECT 
    (i % 500) + 1 AS customer_id,
    NOW() - (i || ' hours')::INTERVAL AS order_date,
    CASE 
        WHEN i % 7 = 0 THEN 'Cancelled'
        WHEN i % 7 = 1 THEN 'Pending'
        ELSE 'Shipped'
    END AS status
FROM generate_series(1, 2000) i;

-- Generate transactional line-item details for orders
INSERT INTO order_details (order_id, product_id, quantity, discount)
SELECT 
    i AS order_id,
    (i % 100) + 1 AS product_id,
    (i % 5) + 1 AS quantity,
    CASE WHEN i % 3 = 0 THEN 0.10 ELSE 0.00 END AS discount
FROM generate_series(1, 2000) i;


-- ============================================================================
-- PHASE 2: BUSINESS INSIGHTS & BASIC DATA FILTERING
-- ============================================================================

-- Query 1: Extract the first 10 loyal customers based on chronological signup date
SELECT 
    customer_id,
    first_name,
    signup_date 
FROM 
    customers 
ORDER BY 
    signup_date ASC 
LIMIT 
    10;

-- Query 2: Audit query to verify customer registration records
SELECT * FROM customers;

-- Query 3: Identify complete customer profiles in target Arab markets for regional campaigns
SELECT 
    customer_id,
    first_name,
    last_name,
    email,
    country
FROM 
    customers 
WHERE 
    country IN ('UAE', 'KSA', 'Egypt')
    AND email IS NOT NULL 
    AND last_name IS NOT NULL; 

-- Query 4: Security audit to catch untrimmed spam/bot accounts starting with 'user_10'
SELECT 
    customer_id,
    first_name,
    last_name,
    email
FROM 
    customers 
WHERE 
    TRIM(email) LIKE 'user_10%';


-- ============================================================================
-- PHASE 3: FINANCIAL METRICS, AGGREGATIONS & ADVANCED JOINS
-- ============================================================================

-- Query 5: Global inventory check summarizing total stock, price stats, and unique categories
SELECT 
    COUNT(DISTINCT category_id) AS Unique_Category,
    AVG(price) AS AVG_Price,
    MAX(price) AS Max_Price,
    MIN(price) AS Min_Price,
    SUM(stock) AS Total_Stock 
FROM 
    products;

-- Query 6: High-volume order status tracking (Filtering statuses with >300 transactions)
SELECT 
    COUNT(order_id) AS Num_Of_Orders,
    status 
FROM 
    orders 
GROUP BY 
    status 
HAVING 
    COUNT(order_id) > 300;

-- Query 7: Master Purchase Journey Report (4-Table Inner Join for complete shipping transparency)
SELECT 
    CONCAT(C.first_name, ' ', C.last_name) AS Full_Name,
    P.product_name,
    P.price,
    OD.quantity,
    O.status
FROM 
    customers C
INNER JOIN orders O ON C.customer_id = O.customer_id
INNER JOIN order_details OD ON O.order_id = OD.order_id
INNER JOIN products P ON OD.product_id = P.product_id;

-- Query 8: Dormant Product Analysis using LEFT JOIN & conditional flags for missing sales
SELECT 
    P.product_name,
    P.price,
    CASE 
        WHEN OD.quantity IS NULL THEN 'No Sales' 
        ELSE CAST(OD.quantity AS VARCHAR) 
    END AS sales_status
FROM 
    products P 
LEFT JOIN order_details OD ON P.product_id = OD.product_id;

-- Query 9: Data Integrity Check combining all existing products and order logs 
SELECT 
    P.product_id,
    P.product_name,
    P.price,
    OD.quantity 
FROM 
    products P 
FULL OUTER JOIN order_details OD ON P.product_id = OD.product_id;

-- Query 10: Marketing Matrix Analysis generating all possible Product-Category bundle pairs
SELECT 
    P.product_name,
    P.price,
    C.category_name
FROM 
    products P 
CROSS JOIN categories C;


-- ============================================================================
-- PHASE 4: TEXT RE-ENGINEERING, SUBQUERIES & DATA PIPELINES
-- ============================================================================

-- Query 11: Dynamic filtering extracting products priced higher than the platform average
SELECT 
    product_name,
    price
FROM 
    products 
WHERE 
    price > (SELECT AVG(price) FROM products);

-- Query 12: Unified Global Index column merging customer names and products for search engines
SELECT first_name FROM customers 
UNION 
SELECT product_name FROM products;

-- Query 13: Data Quality Routine cleansing emails and generating uppercase database names
SELECT
    UPPER(CONCAT(first_name, ' ', last_name)) AS Clean_Full_Name,
    TRIM(LOWER(email)) AS Cleaned_Emails,
    SUBSTRING(TRIM(LOWER(email)), 1, 5) AS Email_Prefix
FROM 
    customers;

-- Query 14: Time-series Analysis isolating active purchase hours alongside audit timestamps
SELECT 
    order_id,
    order_date,
    EXTRACT(HOUR FROM order_date) AS Time_In_Hours,
    NOW() AS Real_Time
FROM 
    orders;
    
-- Query 15: Strategic Pricing Matrix classifying items into competitive marketplace brackets
SELECT 
    product_name,
    price,
    CASE
        WHEN price >= 200 THEN 'Premium'
        WHEN price BETWEEN 100 AND 199.99 THEN 'Mid_Range'
        ELSE 'Budget'
    END AS product_segment
FROM 
    products;

-- Query 16: SQL Pivot Table calculating total quantities sold per country across core categories
SELECT 
    C.country,
    SUM(CASE WHEN CAT.category_name = 'Electronics' THEN OD.quantity ELSE 0 END) AS Electronics_Qty,
    SUM(CASE WHEN CAT.category_name = 'Clothing' THEN OD.quantity ELSE 0 END) AS Clothing_Qty,
    SUM(CASE WHEN CAT.category_name = 'Home & Kitchen' THEN OD.quantity ELSE 0 END) AS Home_Kitchen_Qty,
    SUM(CASE WHEN CAT.category_name = 'Books' THEN OD.quantity ELSE 0 END) AS Books_Qty
FROM 
    customers C
JOIN orders O ON C.customer_id = O.customer_id
JOIN order_details OD ON O.order_id = OD.order_id
JOIN products P ON OD.product_id = P.product_id
JOIN categories CAT ON P.category_id = CAT.category_id
GROUP BY 
    C.country
ORDER BY 
    C.country;

-- Query 17: Production Logistics Data Pipeline isolating active 'Shipped' statuses
CREATE VIEW shipped_orders_view AS
SELECT order_id, customer_id, order_date, status
FROM orders
WHERE status = 'Shipped';
